{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "generic-kargo-pipeline values",
  "type": "object",
  "additionalProperties": false,
  "required": ["global", "application", "warehouse", "sources", "pipeline", "integrations"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "warehouse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "interval", "freightCreationPolicy"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "interval": { "type": "string", "minLength": 1 },
        "freightCreationPolicy": { "type": "string", "enum": ["Automatic", "Manual"] }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "deploymentGit"],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/component" }
        },
        "deploymentGit": { "$ref": "#/definitions/deploymentGit" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prepareRelease", "dev", "integration", "preProduction", "production"],
          "properties": {
            "prepareRelease": { "$ref": "#/definitions/prepareReleaseStage" },
            "dev": { "$ref": "#/definitions/deploymentStage" },
            "integration": { "$ref": "#/definitions/deploymentStage" },
            "preProduction": { "$ref": "#/definitions/basicStage" },
            "production": { "$ref": "#/definitions/deploymentStage" }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serviceNow", "gitLab"],
      "properties": {
        "serviceNow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "credentials"],
          "properties": {
            "enabled": { "type": "boolean" },
            "credentials": {
              "type": "object",
              "additionalProperties": false,
              "required": ["username", "password"],
              "properties": {
                "username": { "type": "string" },
                "password": { "type": "string" }
              }
            }
          }
        },
        "gitLab": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mergeRequest"],
          "properties": {
            "mergeRequest": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "credentials"],
              "properties": {
                "enabled": { "type": "boolean" },
                "credentials": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["token"],
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "enabled", "image", "git", "valuesMapping"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "selectionStrategy": { "type": "string", "enum": ["NewestBuild", "SemVer", "Lexical"] },
            "allowedTags": { "type": "string" },
            "semverConstraint": { "type": "string" },
            "discoveryLimit": { "type": "integer", "minimum": 1 }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "configuration"],
          "properties": {
            "repository": { "$ref": "#/definitions/gitRepository" },
            "configuration": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path"],
              "properties": {
                "path": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "valuesMapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tagPath"],
          "properties": {
            "tagPath": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "deploymentGit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "subscription", "branches", "paths"],
      "properties": {
        "repository": { "$ref": "#/definitions/gitRepository" },
        "subscription": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "branch"],
          "properties": {
            "enabled": { "type": "boolean" },
            "branch": { "type": "string", "minLength": 1 },
            "commitSelectionStrategy": { "type": "string", "minLength": 1 },
            "discoveryLimit": { "type": "integer", "minimum": 1 },
            "includePaths": { "$ref": "#/definitions/pathList" },
            "excludePaths": { "$ref": "#/definitions/pathList" }
          }
        },
        "branches": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "production"],
          "properties": {
            "source": { "type": "string", "minLength": 1 },
            "production": { "type": "string", "minLength": 1 }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["valuesFiles"],
          "properties": {
            "valuesFiles": {
              "type": "object",
              "additionalProperties": false,
              "required": ["base", "environment"],
              "properties": {
                "base": { "type": "string", "minLength": 1 },
                "environment": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "gitRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "username", "password"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "username": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "basicStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" }
      }
    },
    "prepareReleaseStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled", "releaseBranch"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" },
        "releaseBranch": { "type": "string", "minLength": 1 }
      }
    },
    "deploymentStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled", "deployment", "verification"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" },
        "deployment": { "$ref": "#/definitions/deployment" },
        "verification": { "$ref": "#/definitions/verification" }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "argocd"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "argocd": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicationName", "namespace"],
          "properties": {
            "applicationName": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "templateName", "timeout"],
      "properties": {
        "enabled": { "type": "boolean" },
        "templateName": { "type": "string", "minLength": 1 },
        "timeout": { "type": "string", "minLength": 1 },
        "job": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": {
              "type": "object",
              "additionalProperties": false,
              "required": ["repository", "tag"],
              "properties": {
                "repository": { "type": "string", "minLength": 1 },
                "tag": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "pathList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
