{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "generic-kargo-pipeline values",
  "type": "object",
  "additionalProperties": false,
  "required": ["global", "warehouse", "sources", "pipeline"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      }
    },
    "warehouse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "interval", "freightCreationPolicy"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "interval": { "type": "string", "minLength": 1 },
        "freightCreationPolicy": { "type": "string", "enum": ["Automatic", "Manual"] }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "deploymentGit"],
      "properties": {
        "componentDefaults": { "$ref": "#/definitions/componentDefaults" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/component" }
        },
        "deploymentGit": { "$ref": "#/definitions/deploymentGit" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prepareRelease", "dev", "integration", "preProduction", "production"],
          "properties": {
            "prepareRelease": { "$ref": "#/definitions/prepareReleaseStage" },
            "dev": { "$ref": "#/definitions/deploymentStage" },
            "integration": { "$ref": "#/definitions/deploymentStage" },
            "preProduction": { "$ref": "#/definitions/basicStage" },
            "production": { "$ref": "#/definitions/deploymentStage" }
          }
        }
      }
    }
  },
  "definitions": {
    "componentDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "selectionStrategy": { "$ref": "#/definitions/imageSelectionStrategy" },
            "allowedTags": { "type": "string" },
            "semverConstraint": { "type": "string" },
            "strictSemvers": { "type": "boolean" },
            "discoveryLimit": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "image", "git", "releaseConfiguration", "valuesMapping"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifactory"],
          "properties": {
            "artifactory": { "type": "string", "minLength": 1 },
            "selectionStrategy": { "$ref": "#/definitions/imageSelectionStrategy" },
            "allowedTags": { "type": "string" },
            "semverConstraint": { "type": "string" },
            "strictSemvers": { "type": "boolean" },
            "discoveryLimit": { "type": "integer", "minimum": 1 }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": { "$ref": "#/definitions/gitRepository" }
          }
        },
        "releaseConfiguration": {
          "$ref": "#/definitions/releaseConfiguration"
        },
        "valuesMapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tagPath"],
          "properties": {
            "tagPath": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^{}]+$"
            }
          }
        }
      }
    },
    "releaseConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generationEnabled", "outputPath"],
      "properties": {
        "generationEnabled": { "type": "boolean" },
        "devConfigurationPath": { "$ref": "#/definitions/workspaceRelativePath" },
        "deploymentOverlayPath": { "$ref": "#/definitions/workspaceRelativePath" },
        "outputPath": { "$ref": "#/definitions/workspaceRelativePath" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "generationEnabled": { "const": true }
            }
          },
          "then": {
            "required": ["devConfigurationPath", "deploymentOverlayPath"]
          }
        }
      ]
    },
    "deploymentGit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "branches", "subscription", "paths"],
      "properties": {
        "repository": { "$ref": "#/definitions/gitRepository" },
        "branches": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "production"],
          "properties": {
            "source": { "type": "string", "minLength": 1 },
            "production": { "type": "string", "minLength": 1 }
          }
        },
        "subscription": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "commitSelectionStrategy": { "type": "string", "minLength": 1 },
            "discoveryLimit": { "type": "integer", "minimum": 1 },
            "includePaths": { "$ref": "#/definitions/pathList" },
            "excludePaths": { "$ref": "#/definitions/pathList" }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["valuesFiles"],
          "properties": {
            "valuesFiles": {
              "type": "object",
              "additionalProperties": false,
              "required": ["base", "environment"],
              "properties": {
                "base": { "type": "string", "minLength": 1 },
                "environment": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "gitRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "username": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "imageSelectionStrategy": {
      "type": "string",
      "enum": ["NewestBuild", "SemVer", "Lexical"]
    },
    "basicStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" }
      }
    },
    "prepareReleaseStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled", "releaseBranch"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" },
        "releaseBranch": { "type": "string", "minLength": 1 }
      }
    },
    "deploymentStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "autoPromotionEnabled", "deployment", "verification"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "autoPromotionEnabled": { "type": "boolean" },
        "deployment": { "$ref": "#/definitions/deployment" },
        "verification": { "$ref": "#/definitions/verification" }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "argocd"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "argocd": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicationName", "namespace"],
          "properties": {
            "applicationName": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "templateName", "timeout"],
      "properties": {
        "enabled": { "type": "boolean" },
        "templateName": { "type": "string", "minLength": 1 },
        "timeout": { "type": "string", "minLength": 1 }
      }
    },
    "pathList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "workspaceRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\].*$"
    }
  }
}
