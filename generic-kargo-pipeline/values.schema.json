{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "generic-kargo-pipeline values",
  "type": "object",
  "additionalProperties": true,
  "required": ["artifact", "chartGit", "environments"],
  "properties": {
    "global": {
      "type": "object"
    },
    "kargo": {
      "type": "object"
    },
    "artifact": {
      "type": "object",
      "required": ["components"],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/artifactComponent"
          }
        }
      }
    },
    "chartGit": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          }
        },
        "branches": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "production": {
              "type": "string",
              "minLength": 1
            },
            "releaseTemplate": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "paths": {
          "type": "object",
          "properties": {
            "valuesFile": {
              "type": "object",
              "properties": {
                "base": {
                  "type": "string",
                  "minLength": 1
                },
                "environment": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "developersGit": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          }
        },
        "configurationPathFile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prepareRelease": {
      "type": "object",
      "properties": {
        "autoPromotionEnabled": {
          "type": "boolean"
        }
      }
    },
    "environments": {
      "type": "object",
      "required": ["dev", "integration", "production"],
      "properties": {
        "dev": {
          "$ref": "#/definitions/deployEnvironment"
        },
        "integration": {
          "$ref": "#/definitions/deployEnvironment"
        },
        "preProduction": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "autoPromotionEnabled": {
              "type": "boolean"
            }
          }
        },
        "production": {
          "$ref": "#/definitions/deployEnvironment"
        }
      }
    },
    "qa": {
      "$ref": "#/definitions/featureToggle"
    },
    "integrationVerification": {
      "$ref": "#/definitions/featureToggle"
    },
    "productionVerification": {
      "$ref": "#/definitions/featureToggle"
    },
    "serviceNow": {
      "$ref": "#/definitions/featureToggle"
    },
    "gitLab": {
      "type": "object",
      "properties": {
        "mergeRequest": {
          "$ref": "#/definitions/featureToggle"
        }
      }
    }
  },
  "definitions": {
    "artifactComponent": {
      "type": "object",
      "required": ["name", "image"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "selectionStrategy": {
              "type": "string",
              "minLength": 1
            },
            "allowedTags": {
              "type": "string"
            },
            "semverConstraint": {
              "type": "string"
            },
            "discoveryLimit": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "deployEnvironment": {
      "type": "object",
      "required": ["argocd"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "autoPromotionEnabled": {
          "type": "boolean"
        },
        "argocd": {
          "type": "object",
          "required": ["applicationName"],
          "properties": {
            "applicationName": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "verification": {
          "$ref": "#/definitions/featureToggle"
        }
      }
    },
    "featureToggle": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
